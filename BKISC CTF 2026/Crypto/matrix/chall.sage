from secret import FLAG
from Crypto.Util.number import bytes_to_long

p = 61996545789950044511807056126248141945304434838920379595334089328489467238193
assert FLAG.startswith(b"BKISC{") and FLAG.endswith(b"}")
secret_text = FLAG[6:-1]
assert len(secret_text) == 64
assert all(32 <= x <= 126 for x in secret_text)
a, b, c, d = [bytes_to_long(secret_text[i:i+16]) for i in range(0, 64, 16)]
M = Matrix(GF(p), [
    [a, b],
    [c, d]
])
C = M
for i in range(31337):
    C = C^1337

print(f'hints = {C.eigenvalues()}')
print(f'C0 = {str(C[0][0])[:36]}')
print(f'C1 = {str(C[0][1])[:36]}')

